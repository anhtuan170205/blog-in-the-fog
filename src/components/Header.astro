---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="top-bar">
		<a href="/en">EN</a>
		<a href="/vi">VI</a>
	</div>

	<a href="/" class="masthead">{SITE_TITLE}</a>

	<nav class="site-nav">
		<a href="/">Home</a>
		<a href="/blog">Blog</a>
		<a href="/about">About</a>
	</nav>
</header>

<style>
	.site-header {
		padding: 1.5rem 1rem 0;
		text-align: center;
		border-bottom: 3px double rgb(var(--black));
		align-items: center;
	}

	.top-bar {
		display: flex;
		justify-content: center;
		gap: 1rem;
		max-width: 1120px;
		margin: 0 auto 2rem;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.top-bar a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.masthead {
		display: block;
		margin: 0 auto 2rem;
		font-family: "Playfair Display", serif;
		font-size: clamp(2.2rem, 5vw, 3.5rem);
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0.01em;
		color: rgb(var(--black));
		text-decoration: none;
	}

	.site-nav {
		display: flex;
		justify-content: center;
		gap: 2rem;
		padding: 0.8rem 0;
		font-family: "Crimson Text", serif;
		font-size: 0.95rem;
	}

	.site-nav a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.site-nav a:hover {
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	@media (max-width: 720px) {
		.top-bar {
			justify-content: center;
			margin-bottom: 1.5rem;
		}

		.masthead {
			font-size: 3rem;
		}

		.site-nav {
			gap: 1rem;
			overflow-x: auto;
		}
	}
</style>